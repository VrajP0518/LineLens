{
  "name": "linelens-sports",
  "version": "3.0.0",
  "private": true,
  "description": "LineLens Sports desktop prediction dashboard",
  "scripts": {
    "build:web": "python scripts/build_web_dist.py",
    "app": "python scripts/local_server.py --port 4173",
    "app:dist": "npm run build:web && npx http-server dist-web -p 4174",
    "check:js": "node --check app.js && node --check widget.js",
    "check:python": "python -m compileall src scripts",
    "demo:check": "python scripts/demo_check.py",
    "generate:icons": "python scripts/generate_app_icons.py",
    "bootstrap:env": "python scripts/bootstrap_env.py",
    "startup:auto": "python scripts/startup_orchestrator.py",
    "refresh:data": "python scripts/refresh_data.py --sport all --mode current",
    "refresh:startup": "python scripts/startup_orchestrator.py",
    "refresh:data:real": "python scripts/refresh_data.py --sport all --mode real",
    "refresh:mlb": "python scripts/refresh_data.py --sport mlb --mode predict",
    "refresh:mlb:history": "python scripts/refresh_data.py --sport mlb --mode history",
    "refresh:mlb:train": "python scripts/refresh_data.py --sport mlb --mode train",
    "refresh:mlb:predict": "python scripts/refresh_data.py --sport mlb --mode predict",
    "refresh:mlb:all": "python scripts/refresh_data.py --sport mlb --mode all",
    "refresh:mlb:export": "python scripts/refresh_data.py --sport mlb --mode export",
    "refresh:wnba": "python scripts/refresh_data.py --sport wnba --mode predict",
    "refresh:wnba:history": "python scripts/refresh_data.py --sport wnba --mode history",
    "refresh:wnba:train": "python scripts/refresh_data.py --sport wnba --mode train",
    "refresh:wnba:all": "python scripts/refresh_data.py --sport wnba --mode all",
    "refresh:wnba:predict": "python scripts/refresh_data.py --sport wnba --mode predict",
    "build:wnba:props": "python -m src.wnba.props_dataset --mode all",
    "build:mlb:props": "python -m src.mlb.props_dataset --mode all",
    "refresh:wnba:player-boxscores": ".venv\\Scripts\\python.exe scripts/refresh_wnba_player_boxscores.py",
    "refresh:wnba:availability": ".venv\\Scripts\\python.exe scripts/refresh_wnba_availability.py",
    "refresh:mlb:player-games": ".venv\\Scripts\\python.exe scripts/refresh_mlb_player_games.py",
    "refresh:props:pipeline": ".venv\\Scripts\\python.exe scripts/refresh_player_props_pipeline.py",
    "train:wnba:props": ".venv\\Scripts\\python.exe -m src.wnba.train_prop_models",
    "refresh:props": "python scripts/refresh_props.py",
    "export:props": ".venv\\Scripts\\python.exe -m src.wnba.export_prop_predictions",
    "train:mlb:props": ".venv\\Scripts\\python.exe -m src.mlb.train_prop_models",
    "export:mlb:props": ".venv\\Scripts\\python.exe -m src.mlb.export_prop_predictions",
    "score:props": "python scripts/score_prop_predictions.py",
    "refresh:nfl": "python scripts/refresh_data.py --sport nfl --mode export",
    "refresh:nfl:real": "python scripts/refresh_data.py --sport nfl --mode real",
    "refresh:odds": "python scripts/odds_snapshots.py",
    "score:models": "python scripts/score_model_predictions.py",
    "record:models": "python scripts/score_model_predictions.py",
    "check:data": "python scripts/check_data_status.py",
    "check:sprint4": "python scripts/check_sprint4.py",
    "check:props": "python scripts/check_props.py",
    "check:integrity": "python scripts/check_data_integrity.py",
    "verify:release": "python scripts/verify_release.py",
    "refresh:live": "python scripts/live_scores.py",
    "refresh:widget": "python scripts/live_scores.py",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "http-server": "^14.1.1"
  }
}
