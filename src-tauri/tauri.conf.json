{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LineLens Sports",
  "version": "5.6.0",
  "identifier": "com.linelens.sports",
  "build": {
    "beforeDevCommand": "npm run app",
    "devUrl": "http://localhost:4173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist-web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LineLens Sports",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'", "ipc:", "http://ipc.localhost", "asset:"],
        "connect-src": ["'self'", "ipc:", "http://ipc.localhost"],
        "img-src": ["'self'", "asset:", "data:", "blob:", "https://a.espncdn.com"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "font-src": ["'self'", "data:"],
        "script-src": ["'self'"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../scripts": "runtime/scripts",
      "../src": "runtime/src",
      "../data": "runtime/data",
      "../models": "runtime/models",
      "../requirements.txt": "runtime/requirements.txt"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
