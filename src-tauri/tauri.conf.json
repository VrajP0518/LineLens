{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LineLens Sports",
  "version": "0.2.0",
  "identifier": "com.linelens.sports",
  "build": {
    "beforeDevCommand": "npm run app",
    "devUrl": "http://localhost:4173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist-web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LineLens Sports",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
